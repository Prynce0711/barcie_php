# Set PHP timezone for consistent time handling
<IfModule mod_php.c>
    php_value date.timezone "Asia/Manila"
</IfModule>
<IfModule mod_php7.c>
    php_value date.timezone "Asia/Manila"
</IfModule>
<IfModule mod_php8.c>
    php_value date.timezone "Asia/Manila"
</IfModule>

# Prevent aggressive caching of JavaScript and CSS during development
<IfModule mod_headers.c>
    <FilesMatch "\.(js|css)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
</IfModule>

# Protect .env file from being accessed via browser
<Files ".env">
    Order allow,deny
    Deny from all
</Files>

# Also protect other sensitive files (config, logs, backups, etc.)
<FilesMatch "\.(env|log|ini|conf|sql|bak|md)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Protect vendor and sensitive directories
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Route legacy entry files to the single front controller.
    RewriteRule ^(admin|dashboard|guest|logout)\.php$ index.php?view=$1 [QSA,L,NC]
    RewriteRule ^vendor/.*$ - [F,L]
    # Block SQL files only in database folder
    RewriteRule ^database/.*\.sql$ - [F,L]
    RewriteRule ^logs/.*$ - [F,L]
</IfModule>

# Enable mod_rewrite if needed for clean URLs
# RewriteEngine On
